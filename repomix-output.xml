// Agent 1 — Policy Agent (ReAct-style tool pipeline).
// Reads a policy PDF and produces a frozen, validated rule set.
import { pdfTextExtractor, pdfTableExtractor } from '../tools/pdfTools.js';
import { irdaiRegulationLookup, ruleValidator } from '../tools/policyTools.js';
import { complete } from '../services/llmService.js';

const RULE_TYPES = ['room_rent', 'sub_limit', 'waiting_period', 'co_pay', 'deductible', 'exclusion'];

// AI-assisted extraction — used when the regex heuristics find too few rules and
// an LLM provider is configured (free tiers work: Cerebras/Groq/OpenRouter).
const aiExtractPolicy = async (text, userId) => {
  const system =
    'You are an expert at reading Indian health-insurance policy documents. Extract EVERY rule exhaustively as STRICT JSON only — no prose, no markdown fences.';
  const prompt = `From the policy text below, extract this JSON object:
{
  "planName": string,   // the INSURANCE PRODUCT / plan name (e.g. "Health Companion", "ReAssure 2.0") — NEVER the policyholder's personal name or a title like "Mr"
  "insurer": string,
  "sumInsured": number,
  "rules": [ { "type": "room_rent"|"sub_limit"|"waiting_period"|"co_pay"|"deductible"|"exclusion", "label": string, "params": object, "clauseRef": string } ]
}
Params by type:
- room_rent: {"percentOfSumInsured": number} OR {"absolutePerDay": number}
- sub_limit: {"procedure": lowercase string, "cap": number}
- waiting_period: {"procedure": lowercase string, "months": number}
- co_pay: {"percent": number}
- deductible: {"amount": number}
- exclusion: {"match": lowercase keyword}

BE EXHAUSTIVE — extract EVERY rule found ANYWHERE in the document, including every
row of any Benefit / Sub-limit / Schedule table:
- one rule object per sub-limit (e.g. each capped procedure or benefit is its own sub_limit)
- the room-rent cap (per-day amount or % of sum insured)
- every waiting period (initial, pre-existing, specific-disease — convert to months)
- any co-payment % and any deductible amount
- key exclusions
Do NOT omit any rule. If a value is a table row "X ........ ₹Y", that is a sub_limit {procedure:"x", cap:Y}.

Policy text:
"""${String(text).slice(0, 16000)}"""

Return ONLY the JSON object.`;

  const { text: out, degraded, reason, error, provider, model } = await complete({ prompt, system, temperature: 0, maxTokens: 4096, useCache: false, userId });
  if (degraded || !out) return { degraded: true, reason, error };
  try {
    const obj = JSON.parse(out.slice(out.indexOf('{'), out.lastIndexOf('}') + 1));
    const rules = Array.isArray(obj.rules) ? obj.rules.filter((r) => RULE_TYPES.includes(r?.type)) : [];
    return { planName: obj.planName, insurer: obj.insurer, sumInsured: Number(obj.sumInsured) || 0, rules, provider, model };
  } catch {
    return { parseError: true };
  }
};

// Heuristic rule extraction from raw policy text. In production an LLM assists,
// but the validator + freeze guarantees a deterministic, immutable rule set.
const extractRulesFromText = (text, tables) => {
  const rules = [];
  const t = String(text || '');

  // Room rent: "1% of sum insured" or "Rs. 5000 per day".
  const pctRoom = t.match(/room\s+rent[^.]*?(\d+(?:\.\d+)?)\s*%/i);
  const absRoom = t.match(/room\s+rent[^.]*?(?:rs\.?|₹)\s*([\d,]+)\s*(?:per day|\/day)/i);
  if (pctRoom) {
    rules.push({ type: 'room_rent', label: 'Room rent cap', params: { percentOfSumInsured: Number(pctRoom[1]) }, clauseRef: 'Room Rent' });
  } else if (absRoom) {
    rules.push({ type: 'room_rent', label: 'Room rent cap', params: { absolutePerDay: Number(absRoom[1].replace(/,/g, '')) }, clauseRef: 'Room Rent' });
  }

  // Co-pay: "co-payment of 20%".
  const coPay = t.match(/co[\s-]?pay(?:ment)?[^.]*?(\d+)\s*%/i);
  if (coPay) rules.push({ type: 'co_pay', label: 'Co-payment', params: { percent: Number(coPay[1]) }, clauseRef: 'Co-payment' });

  // Deductible.
  const ded = t.match(/deductible[^.]*?(?:rs\.?|₹)\s*([\d,]+)/i);
  if (ded) rules.push({ type: 'deductible', label: 'Deductible', params: { amount: Number(ded[1].replace(/,/g, '')) }, clauseRef: 'Deductible' });

  // Waiting period: "cataract ... 24 months".
  const wait = t.match(/(\w[\w\s]+?)\s+(?:waiting period|after)\s+(\d+)\s*months/i);
  if (wait) rules.push({ type: 'waiting_period', label: `${wait[1].trim()} waiting period`, params: { procedure: wait[1].trim().toLowerCase(), months: Number(wait[2]) }, clauseRef: 'Waiting Period' });

  // Sub-limit from tables: rows that name a procedure and an amount.
  for (const row of tables.rows || []) {
    const amount = row.map((c) => c.replace(/[₹,]/g, '')).find((c) => /^\d{4,}$/.test(c));
    if (amount && /cataract|knee|hernia|maternity|cardiac/i.test(row.join(' '))) {
      rules.push({ type: 'sub_limit', label: `${row[0]} sub-limit`, params: { procedure: row[0].toLowerCase(), cap: Number(amount) }, clauseRef: 'Sub-limits' });
    }
  }

  // Exclusions: "cosmetic surgery is excluded".
  for (const m of t.matchAll(/([\w\s]+?)\s+(?:is|are)\s+excluded/gi)) {
    const label = m[1].trim();
    if (label.length < 40) rules.push({ type: 'exclusion', label: `${label} excluded`, params: { match: label.toLowerCase() }, clauseRef: 'Exclusions' });
  }

  return rules;
}

// Reject junk plan names (policyholder-field captures, bare titles, too short).
const cleanPlanName = (s) => {
  const v = String(s || '').trim().replace(/\s+/g, ' ');
  if (v.length < 3) return '';
  if (/policyholder|insured name|^name\b|^(mr|mrs|ms|dr|m\/s)\b/i.test(v)) return '';
  return v.slice(0, 60);
};

const extractMeta = (text) => {
  const t = String(text || '');
  const sum = t.match(/sum\s+insured[^\d]*(?:rs\.?|₹)?\s*([\d,]+)/i);
  const insurer = t.match(/(star health|hdfc ergo|icici lombard|niacl|new india|oriental|national insurance|care health|max bupa|bajaj allianz)/i);
  const plan = t.match(/(?:plan|policy)\s*(?:name)?[:\-]?\s*([A-Z][A-Za-z0-9 ]{3,40})/);
  return {
    sumInsured: sum ? Number(sum[1].replace(/,/g, '')) : 0,
    insurer: insurer ? insurer[1] : 'Unknown Insurer',
    planName: plan ? plan[1].trim() : 'Uploaded Policy',
  };
}

export const runPolicyAgent = async ({ buffer, audit, userId }) => {
  let started = Date.now();
  const textResult = await pdfTextExtractor(buffer);
  await audit.log({ agent: 'PolicyAgent', tool: 'pdf_text_extractor', input: `${buffer.length} bytes`, output: { pages: textResult.pages, chars: textResult.text.length }, startedAt: started });

  started = Date.now();
  const tables = pdfTableExtractor(textResult.text);
  await audit.log({ agent: 'PolicyAgent', tool: 'pdf_table_extractor', input: 'raw text', output: { rows: tables.rows.length }, startedAt: started });

  let draftRules = extractRulesFromText(textResult.text, tables);
  let meta = extractMeta(textResult.text);
  let mode = 'heuristic';

  // Fall back to AI extraction when the regex finds too few rules (real insurer
  // PDFs vary too much for heuristics). No-op if no LLM key is configured.
  let aiStatus = null;
  if (draftRules.length < 2) {
    started = Date.now();
    const ai = await aiExtractPolicy(textResult.text, userId);
    aiStatus = ai;
    await audit.log({
      agent: 'PolicyAgent',
      tool: 'ai_rule_extractor',
      input: `${textResult.text.length} chars`,
      output: { degraded: Boolean(ai.degraded), reason: ai.reason, rules: ai.rules?.length || 0, provider: ai.provider || 'none' },
      status: ai.degraded ? 'failure' : 'success',
      startedAt: started,
    });
    if (ai.rules?.length) {
      draftRules = ai.rules;
      mode = 'ai';
    }
    if (!ai.degraded && !ai.parseError) {
      // The AI read the whole document — prefer its values over the brittle regex.
      if (ai.planName) meta = { ...meta, planName: ai.planName };
      if (ai.insurer) meta = { ...meta, insurer: ai.insurer };
      if (ai.sumInsured) meta = { ...meta, sumInsured: ai.sumInsured };
    }
  }

  // Final guard so a junk plan name (e.g. a policyholder title) never sticks.
  const cleaned = cleanPlanName(meta.planName);
  meta.planName = cleaned || (meta.insurer && meta.insurer !== 'Unknown Insurer' ? `${meta.insurer} Policy` : 'Uploaded Policy');

  started = Date.now();
  const regRefs = draftRules.map((r) => ({ type: r.type, regs: irdaiRegulationLookup({ ruleType: r.type }).map((x) => x.code) }));
  await audit.log({ agent: 'PolicyAgent', tool: 'irdai_regulation_lookup', input: draftRules.map((r) => r.type), output: regRefs, startedAt: started });

  started = Date.now();
  const validated = ruleValidator(draftRules);
  await audit.log({ agent: 'PolicyAgent', tool: 'rule_validator', input: { count: draftRules.length, mode }, output: { valid: validated.valid, issues: validated.issues }, status: validated.valid ? 'success' : 'failure', startedAt: started });

  // Human-readable reason when no rules came out, so the user isn't left guessing.
  let extractionNote = null;
  if (!validated.rules.length) {
    const textLen = (textResult.text || '').trim().length;
    if (textLen < 40) {
      extractionNote = 'This PDF has no extractable text — it looks like a scanned image. Try a text-based policy PDF.';
    } else if (aiStatus?.reason === 'no-key') {
      extractionNote = 'No LLM key was reachable. Add one in Settings → AI provider keys (or Admin → API Keys) and re-upload. If you just added/changed one, restart the backend.';
    } else if (aiStatus?.reason === 'provider-error') {
      extractionNote = `AI extraction failed — ${aiStatus.error || 'the provider returned an error'}. Check the key (and that it's enabled), then re-upload.`;
    } else if (aiStatus?.parseError) {
      extractionNote = 'The AI responded but not in the expected format. Re-upload to retry, or add rules manually.';
    } else if (!aiStatus) {
      extractionNote = 'Could not recognise rules in this policy format.';
    } else {
      extractionNote = 'The AI could not extract rules from this policy. You can add rules manually on the policy page.';
    }
  }

  return {
    meta,
    rules: validated.rules,
    rawTextSnippet: textResult.text.slice(0, 1000),
    validation: validated,
    extractionMode: mode,
    extractionNote,
  };
}
