                    <div className="flex justify-end gap-2">
                      <button className="ss-btn-secondary py-1.5 px-3" onClick={() => setEditing(u)}>{t('common.edit')}</button>
                      <button
                        className="ss-btn-ghost py-1.5 px-3 text-taupe disabled:opacity-40"
