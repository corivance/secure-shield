const { Schema } = mongoose;

// User-facing notifications emitted by pipeline events (checks, disputes, uploads).
const notificationSchema = new Schema(
  {
    user: { type: Schema.Types.ObjectId, ref: 'User', required: true, index: true },
    type: {
