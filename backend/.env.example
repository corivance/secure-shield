# SecureShield backend — infrastructure secrets ONLY.
# Provider/API keys are NEVER stored here; they live AES-256 encrypted in
# MongoDB (ai_key_configs) and are resolved with resolveKey(keyName).

PORT=4000
NODE_ENV=development

# Mongo & Redis
MONGODB_URI=mongodb://localhost:27017/secureshield
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Encryption for ai_key_configs (32-byte hex / base64 key)
AES_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Master HMAC API key for CLI/MCP fallback (X-API-Key)
MASTER_API_KEY=dev-master-api-key

# NOTE: Provider/LLM keys (Cerebras, Groq, OpenRouter, Gemini, Google Vision) are
# NEVER set here. A super-admin adds them — AES-256 encrypted in ai_key_configs —
# via the in-app Admin → API Keys screen.
